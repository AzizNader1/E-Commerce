@model E_Commerce.MVC.DTOs.OtpDTOs.OtpVerificationDto

@{
    ViewData["Title"] = "Verify OTP";
    Layout = null;
    var generatedOtp = ViewBag.GeneratedOtp as string;
    var otpAction = ViewBag.OtpAction as string ?? "Verification";
    var userEmail = ViewBag.UserEmail as string;
    var remainingSeconds = ViewBag.RemainingSeconds as int? ?? 300;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP — E-Commerce</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Design System -->
    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/account/login.css" />
    <style>
        /* OTP Alert Modal */
        .otp-alert-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            animation: fadeIn 0.3s ease;
        }

        .otp-alert-overlay.hidden {
            display: none;
        }

        .otp-alert-card {
            background: linear-gradient(145deg, rgba(30, 27, 75, 0.95), rgba(15, 12, 41, 0.98));
            border: 1px solid rgba(168, 85, 247, 0.3);
            border-radius: 20px;
            padding: 40px;
            max-width: 420px;
            width: 90%;
            text-align: center;
            box-shadow: 0 25px 80px rgba(124, 58, 237, 0.4);
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .otp-alert-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 24px;
            background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(6, 182, 212, 0.2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse 2s infinite;
        }

        .otp-alert-icon svg {
            width: 40px;
            height: 40px;
            color: #a855f7;
        }

        .otp-alert-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 12px;
        }

        .otp-alert-subtitle {
            font-size: 0.95rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .otp-display-box {
            background: rgba(168, 85, 247, 0.1);
            border: 2px dashed rgba(168, 85, 247, 0.5);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 24px;
        }

        .otp-display-label {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .otp-display-code {
            font-size: 2.5rem;
            font-weight: 800;
            color: #a855f7;
            letter-spacing: 12px;
            font-family: 'Courier New', monospace;
        }

        .otp-copy-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: linear-gradient(135deg, #7c3aed, #06b6d4);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 16px;
        }

        .otp-copy-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.5);
        }

        .otp-copy-btn.copied {
            background: linear-gradient(135deg, #10b981, #059669);
        }

        .otp-alert-close {
            padding: 12px 32px;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .otp-alert-close:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.3);
        }

        /* OTP Input Form */
        .otp-input-container {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin: 24px 0;
        }

        .otp-input {
            width: 52px;
            height: 60px;
            text-align: center;
            font-size: 1.5rem;
            font-weight: 700;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: #fff;
            transition: all 0.3s ease;
            caret-color: #a855f7;
        }

        .otp-input:focus {
            outline: none;
            border-color: #a855f7;
            background: rgba(168, 85, 247, 0.1);
            box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
        }

        .otp-input.filled {
            border-color: #10b981;
            background: rgba(16, 185, 129, 0.1);
        }

        .otp-input.error {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            animation: shake 0.5s ease;
        }

        .otp-timer {
            text-align: center;
            margin-bottom: 20px;
        }

        .otp-timer-text {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
        }

        .otp-timer-value {
            font-weight: 700;
            color: #a855f7;
        }

        .otp-timer-value.expired {
            color: #ef4444;
        }

        .otp-resend-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: transparent;
            border: 1px solid rgba(168, 85, 247, 0.3);
            border-radius: 10px;
            color: #a855f7;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .otp-resend-btn:hover:not(:disabled) {
            background: rgba(168, 85, 247, 0.1);
            border-color: #a855f7;
        }

        .otp-resend-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-verify {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #7c3aed, #06b6d4);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-verify:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(124, 58, 237, 0.5);
        }

        .btn-verify:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-5px); }
            40%, 80% { transform: translateX(5px); }
        }

        .error-banner {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            color: #f87171;
            font-size: 0.9rem;
        }

        .cancel-link {
            text-align: center;
            margin-top: 20px;
        }

        .cancel-link a {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.85rem;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .cancel-link a:hover {
            color: #ef4444;
        }
    </style>
</head>
<body>

    <!-- OTP Alert Modal (Shows first) -->
    <div class="otp-alert-overlay" id="otpAlertOverlay">
        <div class="otp-alert-card">
            <div class="otp-alert-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
            </div>
            <h2 class="otp-alert-title">Verification Code</h2>
            <p class="otp-alert-subtitle">
                Your One-Time Password for <strong>@otpAction</strong> has been generated.
                <br><small style="color: rgba(255,255,255,0.5);">(@(userEmail ?? "your account"))</small>
            </p>
            <div class="otp-display-box">
                <div class="otp-display-label">Your OTP Code</div>
                <div class="otp-display-code" id="displayOtp">@generatedOtp</div>
            </div>
            <button type="button" class="otp-copy-btn" id="copyOtpBtn" onclick="copyOtp()">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                </svg>
                <span id="copyBtnText">Copy Code</span>
            </button>
            <br>
            <button type="button" class="otp-alert-close" onclick="closeAlert()">
                I've copied my code — Continue
            </button>
        </div>
    </div>

    <!-- Main OTP Verification Page -->
    <div class="login-page">

        <!-- Floating Particles -->
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>

        <div class="login-card">

            <!-- Back to Home -->
            <div class="auth-back-row">
                <a asp-action="CancelOtp" asp-controller="Accounts" class="auth-back-link">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </span>
                    <span class="text">Cancel</span>
                </a>
            </div>

            <!-- Brand / Logo -->
            <div class="login-brand">
                <div class="brand-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </div>
                <h1>Verify Your Identity</h1>
                <p>Enter the 6-digit code we provided</p>
            </div>

            <!-- Error Banner -->
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="error-banner">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    <span>@ViewBag.ErrorMessage</span>
                </div>
            }

            <!-- Timer -->
            <div class="otp-timer">
                <span class="otp-timer-text">Code expires in </span>
                <span class="otp-timer-value" id="timerDisplay">@TimeSpan.FromSeconds(remainingSeconds).ToString(@"mm\:ss")</span>
            </div>

            <!-- OTP Verification Form -->
            <form asp-action="VerifyOtp" asp-controller="Accounts" method="post" id="otpForm">
                @Html.AntiForgeryToken()

                <div class="otp-input-container">
                    <input type="text" class="otp-input" maxlength="1" data-index="0" inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input" maxlength="1" data-index="1" inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input" maxlength="1" data-index="2" inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input" maxlength="1" data-index="3" inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input" maxlength="1" data-index="4" inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input" maxlength="1" data-index="5" inputmode="numeric" pattern="[0-9]" />
                </div>

                <!-- Hidden input for the full OTP -->
                <input type="hidden" asp-for="OtpCode" id="otpCodeHidden" />

                <button type="submit" class="btn-verify" id="btnVerify">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                    Verify & Continue
                </button>
            </form>

            <!-- Resend OTP -->
            <div style="text-align: center; margin-top: 20px;">
                <button type="button" class="otp-resend-btn" id="resendBtn" onclick="resendOtp()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                        <path d="M3 3v5h5" />
                        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                        <path d="M16 16h5v5" />
                    </svg>
                    Resend Code
                </button>
            </div>

            <!-- Cancel Link -->
            <div class="cancel-link">
                <a asp-action="CancelOtp" asp-controller="Accounts">Cancel verification</a>
            </div>

        </div>
    </div>

    <script>
        const otpInputs = document.querySelectorAll('.otp-input');
        const otpHidden = document.getElementById('otpCodeHidden');
        const timerDisplay = document.getElementById('timerDisplay');
        const otpAlertOverlay = document.getElementById('otpAlertOverlay');
        const displayOtp = document.getElementById('displayOtp');

        let remainingSeconds = @remainingSeconds;
        let timerInterval;

        // Copy OTP to clipboard
        function copyOtp() {
            const otp = displayOtp.textContent.trim();
            navigator.clipboard.writeText(otp).then(() => {
                const btn = document.getElementById('copyOtpBtn');
                const btnText = document.getElementById('copyBtnText');
                btn.classList.add('copied');
                btnText.textContent = 'Copied!';
                setTimeout(() => {
                    btn.classList.remove('copied');
                    btnText.textContent = 'Copy Code';
                }, 2000);
            });
        }

        // Close alert and show form
        function closeAlert() {
            otpAlertOverlay.classList.add('hidden');
            startTimer();
            otpInputs[0].focus();
        }

        // Timer countdown
        function startTimer() {
            timerInterval = setInterval(() => {
                remainingSeconds--;
                if (remainingSeconds <= 0) {
                    clearInterval(timerInterval);
                    timerDisplay.textContent = 'Expired';
                    timerDisplay.classList.add('expired');
                    document.getElementById('resendBtn').disabled = false;
                } else {
                    const minutes = Math.floor(remainingSeconds / 60);
                    const seconds = remainingSeconds % 60;
                    timerDisplay.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                }
            }, 1000);
        }

        // Handle OTP input
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                const value = e.target.value;

                // Only allow digits
                if (!/^\d*$/.test(value)) {
                    e.target.value = '';
                    return;
                }

                if (value.length === 1) {
                    input.classList.add('filled');
                    // Move to next input
                    if (index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                }

                updateHiddenInput();
            });

            input.addEventListener('keydown', (e) => {
                // Handle backspace
                if (e.key === 'Backspace') {
                    if (input.value === '' && index > 0) {
                        otpInputs[index - 1].focus();
                        otpInputs[index - 1].value = '';
                        otpInputs[index - 1].classList.remove('filled');
                    } else {
                        input.classList.remove('filled');
                    }
                    updateHiddenInput();
                }
            });

            // Handle paste
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);

                pastedData.split('').forEach((char, i) => {
                    if (otpInputs[i]) {
                        otpInputs[i].value = char;
                        otpInputs[i].classList.add('filled');
                    }
                });

                updateHiddenInput();

                // Focus the next empty input or the last one
                const nextEmpty = [...otpInputs].find(inp => inp.value === '');
                if (nextEmpty) {
                    nextEmpty.focus();
                } else {
                    otpInputs[otpInputs.length - 1].focus();
                }
            });
        });

        function updateHiddenInput() {
            const otp = [...otpInputs].map(input => input.value).join('');
            otpHidden.value = otp;
        }

        // Resend OTP
        function resendOtp() {
            const btn = document.getElementById('resendBtn');
            btn.disabled = true;
            btn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     style="animation: spin 1s linear infinite;">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                </svg>
                Sending...
            `;

            fetch('@Url.Action("ResendOtp", "Accounts")', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update displayed OTP
                    displayOtp.textContent = data.otp;

                    // Reset timer
                    remainingSeconds = data.expirationMinutes * 60;
                    timerDisplay.classList.remove('expired');

                    // Clear inputs
                    otpInputs.forEach(input => {
                        input.value = '';
                        input.classList.remove('filled');
                    });
                    otpInputs[0].focus();

                    // Show alert again with new OTP
                    otpAlertOverlay.classList.remove('hidden');
                    clearInterval(timerInterval);
                } else {
                    alert(data.message || 'Failed to resend OTP');
                }
            })
            .catch(() => {
                alert('An error occurred. Please try again.');
            })
            .finally(() => {
                btn.disabled = false;
                btn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                        <path d="M3 3v5h5" />
                        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                        <path d="M16 16h5v5" />
                    </svg>
                    Resend Code
                `;
            });
        }

        // Form submission
        document.getElementById('otpForm').addEventListener('submit', (e) => {
            const otp = otpHidden.value;
            if (otp.length !== 6) {
                e.preventDefault();
                otpInputs.forEach(input => input.classList.add('error'));
                setTimeout(() => {
                    otpInputs.forEach(input => input.classList.remove('error'));
                }, 500);
                return;
            }
        });

        // Auto-focus first input when page loads (after alert is closed)
        // The alert is shown first, so focus happens in closeAlert()
    </script>

    <style>
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>

</body>
</html>
