@model E_Commerce.MVC.DTOs.CartDTOs.CartShoppingDto

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = null;
    var userName = (string?)TempData["UserName"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopping Cart — E-Commerce</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/shared/home.css" />
    <link rel="stylesheet" href="~/css/cart/cart.css" />
</head>
<body>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer">
        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="toast toast-success" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Success!</div>
                    <div class="toast-message">@successMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="toast toast-error" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Error!</div>
                    <div class="toast-message">@errorMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }
    </div>

    <div class="landing-page cart-page">
        <!-- Background Orbs -->
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>

        <!-- NAVBAR -->
        <nav class="landing-nav scrolled" id="navbar">
            <a class="nav-logo" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 01-8 0"></path></svg>
                </div>
                <span class="logo-text">E-<span>Commerce</span></span>
            </a>

            <div class="nav-actions">
                @if (!string.IsNullOrEmpty(userName))
                {
                    <a asp-controller="Carts" asp-action="Index" class="nav-btn nav-btn-ghost cart-nav-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                        <span>Cart</span>
                        @if (Model != null && Model.TotalItems > 0)
                        {
                            <span class="cart-badge" id="navCartBadge">@Model.TotalItems</span>
                        }
                    </a>
                    <a asp-controller="Accounts" asp-action="UserProfile" asp-route-userName="@userName" class="nav-btn nav-btn-ghost">My Profile</a>
                    <a asp-controller="Accounts" asp-action="Logout" class="nav-btn nav-btn-ghost">Logout</a>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                    <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
                }
            </div>
        </nav>

        <div class="cart-container">
            @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
            {
                <!-- Empty Cart -->
                <div class="cart-items-section">
                    <div class="empty-cart">
                        <div class="empty-cart-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                        </div>
                        <h2>Your cart is empty</h2>
                        <p>Looks like you haven't added anything to your cart yet.</p>
                        <a asp-controller="Home" asp-action="Index">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                            Start Shopping
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="cart-header">
                    <h1>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                        Shopping Cart
                    </h1>
                    <span class="cart-count" id="cartCount">@Model.TotalItems items</span>
                </div>

                <div class="cart-layout">
                    <!-- Cart Items -->
                    <div class="cart-items-section">
                        <div class="cart-items-header">
                            <span>Product</span>
                            <span>Price</span>
                            <span>Quantity</span>
                            <span>Total</span>
                            <span></span>
                        </div>

                        @foreach (var item in Model.CartItems)
                        {
                            <div class="cart-item" data-cart-item-id="@item.CartItemId" data-product-price="@item.ProductPrice" data-stock-quantity="@item.ProductStockQuantity">
                                <div class="cart-item-product">
                                    <img src="@item.ImageSrc" alt="@item.ProductName" class="cart-item-image" />
                                    <div class="cart-item-info">
                                        <h3>@item.ProductName</h3>
                                        <p>@item.CategoryName</p>
                                        @if (item.ProductStockQuantity <= 5 && item.ProductStockQuantity > 0)
                                        {
                                            <p class="stock-warning">Only @item.ProductStockQuantity left in stock</p>
                                        }
                                    </div>
                                </div>

                                <div class="cart-item-price">$@item.ProductPrice.ToString("0.00")</div>

                                <div class="quantity-controls">
                                    <button type="button" class="qty-btn qty-decrease" data-cart-item-id="@item.CartItemId" @(item.Quantity <= 1 ? "disabled" : "")>-</button>
                                    <span class="qty-value" id="qty-@item.CartItemId">@item.Quantity</span>
                                    <button type="button" class="qty-btn qty-increase" data-cart-item-id="@item.CartItemId" @(item.Quantity >= item.ProductStockQuantity ? "disabled" : "")>+</button>
                                </div>

                                <div class="cart-item-total" id="total-@item.CartItemId">$@item.TotalPrice.ToString("0.00")</div>

                                <form asp-action="RemoveItem" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" class="remove-btn" title="Remove item">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>

                    <!-- Cart Summary -->
                    <div class="cart-summary">
                        <h2 class="summary-title">Order Summary</h2>

                        <div class="summary-row">
                            <span class="summary-label">Subtotal (<span id="subtotalItems">@Model.TotalItems</span> items)</span>
                            <span class="summary-value" id="subtotalPrice">$@Model.TotalPrice.ToString("0.00")</span>
                        </div>

                        <div class="summary-row">
                            <span class="summary-label">Shipping</span>
                            <span class="summary-value">Free</span>
                        </div>

                        <div class="summary-row">
                            <span class="summary-label">Tax</span>
                            <span class="summary-value">$0.00</span>
                        </div>

                        <div class="summary-row summary-total">
                            <span class="summary-label">Total</span>
                            <span class="summary-value" id="totalPrice">$@Model.TotalPrice.ToString("0.00")</span>
                        </div>

                        <form asp-controller="Orders" asp-action="Checkout" method="get">
                            <button type="submit" class="checkout-btn enabled" id="checkoutBtn">
                                Proceed to Checkout
                            </button>
                        </form>

                        <a asp-controller="Home" asp-action="Index" class="continue-shopping">
                            ← Continue Shopping
                        </a>

                        <form asp-action="ClearCart" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="clear-cart-btn">Clear Cart</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- FOOTER -->
        <footer class="landing-footer">
            <p>&copy; 2025 E-Commerce. All rights reserved.</p>
        </footer>
    </div>

    @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
    {
        <script>
            // Cart data for client-side calculations
            const cartItems = {
                @foreach (var item in Model.CartItems)
                {
                        <text>'@item.CartItemId': { price: @item.ProductPrice, quantity: @item.Quantity, stock: @item.ProductStockQuantity },</text>
                }
            };

            // Format number as currency
            function formatCurrency(amount) {
                return '$' + amount.toFixed(2);
            }

            // Update all totals
            function updateCartTotals() {
                let totalItems = 0;
                let totalPrice = 0;

                for (const id in cartItems) {
                    const item = cartItems[id];
                    totalItems += item.quantity;
                    totalPrice += item.price * item.quantity;

                    // Update individual item total
                    const totalElement = document.getElementById('total-' + id);
                    if (totalElement) {
                        totalElement.textContent = formatCurrency(item.price * item.quantity);
                    }

                    // Update quantity display
                    const qtyElement = document.getElementById('qty-' + id);
                    if (qtyElement) {
                        qtyElement.textContent = item.quantity;
                    }
                }

                // Update cart count
                const cartCount = document.getElementById('cartCount');
                if (cartCount) {
                    cartCount.textContent = totalItems + ' item' + (totalItems !== 1 ? 's' : '');
                }

                // Update nav badge
                const navBadge = document.getElementById('navCartBadge');
                if (navBadge) {
                    navBadge.textContent = totalItems;
                }

                // Update summary
                const subtotalItems = document.getElementById('subtotalItems');
                if (subtotalItems) {
                    subtotalItems.textContent = totalItems;
                }

                const subtotalPrice = document.getElementById('subtotalPrice');
                if (subtotalPrice) {
                    subtotalPrice.textContent = formatCurrency(totalPrice);
                }

                const totalPriceEl = document.getElementById('totalPrice');
                if (totalPriceEl) {
                    totalPriceEl.textContent = formatCurrency(totalPrice);
                }
            }

            // Get anti-forgery token
            function getAntiForgeryToken() {
                const inputs = document.querySelectorAll('input[name="__RequestVerificationToken"]');
                return inputs.length > 0 ? inputs[0].value : '';
            }

            // Save to server (debounced)
            const saveTimeouts = {};
            function saveToServer(cartItemId, quantity) {
                // Clear existing timeout
                if (saveTimeouts[cartItemId]) {
                    clearTimeout(saveTimeouts[cartItemId]);
                }

                // Debounce the save
                saveTimeouts[cartItemId] = setTimeout(() => {
                    const formData = new FormData();
                    formData.append('cartItemId', cartItemId);
                    formData.append('quantity', quantity);
                    formData.append('__RequestVerificationToken', getAntiForgeryToken());

                    fetch('/Carts/UpdateQuantity', {
                        method: 'POST',
                        body: formData
                    }).then(response => response.json())
                      .then(data => {
                          if (!data.success) {
                              console.error('Failed to update:', data.message);
                          }
                      })
                      .catch(error => {
                          console.error('Failed to update cart:', error);
                      });
                }, 500);
            }

            // Initialize quantity buttons
            document.querySelectorAll('.qty-increase').forEach(btn => {
                btn.addEventListener('click', function() {
                    const cartItemId = this.getAttribute('data-cart-item-id');
                    const item = cartItems[cartItemId];
                    if (!item) return;

                    if (item.quantity < item.stock) {
                        item.quantity++;
                        updateCartTotals();
                        updateButtonStates(cartItemId);
                        saveToServer(cartItemId, item.quantity);
                    }
                });
            });

            document.querySelectorAll('.qty-decrease').forEach(btn => {
                btn.addEventListener('click', function() {
                    const cartItemId = this.getAttribute('data-cart-item-id');
                    const item = cartItems[cartItemId];
                    if (!item) return;

                    if (item.quantity > 1) {
                        item.quantity--;
                        updateCartTotals();
                        updateButtonStates(cartItemId);
                        saveToServer(cartItemId, item.quantity);
                    }
                });
            });

            // Update button states (enable/disable)
            function updateButtonStates(cartItemId) {
                const item = cartItems[cartItemId];
                if (!item) return;

                const cartItem = document.querySelector('[data-cart-item-id="' + cartItemId + '"]');
                if (!cartItem) return;

                const decreaseBtn = cartItem.querySelector('.qty-decrease');
                const increaseBtn = cartItem.querySelector('.qty-increase');

                if (decreaseBtn) {
                    decreaseBtn.disabled = item.quantity <= 1;
                }

                if (increaseBtn) {
                    increaseBtn.disabled = item.quantity >= item.stock;
                }
            }
        </script>
    }

    <script>
        // Toast functions
        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('hiding');
            setTimeout(() => toast.remove(), 300);
        }

        document.querySelectorAll('.toast').forEach(toast => {
            setTimeout(() => {
                if (toast && !toast.classList.contains('hiding')) {
                    toast.classList.add('hiding');
                    setTimeout(() => toast.remove(), 300);
                }
            }, 5000);
        });
    </script>
</body>
</html>
