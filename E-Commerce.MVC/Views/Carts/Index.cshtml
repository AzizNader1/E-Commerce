@model E_Commerce.MVC.DTOs.CartDTOs.CartShoppingDto

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = null;
    var userName = (string?)TempData["UserName"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopping Cart — E-Commerce</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/shared/home.css" />
    <link rel="stylesheet" href="~/css/cart/cart.css" />
    <style>
        /* Selection Checkbox Styles */
        .cart-item-checkbox {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
        }

        .custom-checkbox {
            position: relative;
            width: 22px;
            height: 22px;
            cursor: pointer;
        }

            .custom-checkbox input {
                position: absolute;
                opacity: 0;
                cursor: pointer;
                height: 0;
                width: 0;
            }

        .checkmark {
            position: absolute;
            top: 0;
            left: 0;
            height: 22px;
            width: 22px;
            background-color: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--border-glass);
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .custom-checkbox:hover input ~ .checkmark {
            background-color: rgba(168, 85, 247, 0.1);
            border-color: var(--primary-light);
        }

        .custom-checkbox input:checked ~ .checkmark {
            background-color: var(--primary);
            border-color: var(--primary);
        }

        .checkmark:after {
            content: "";
            position: absolute;
            display: none;
        }

        .custom-checkbox input:checked ~ .checkmark:after {
            display: block;
        }

        .custom-checkbox .checkmark:after {
            left: 6px;
            top: 2px;
            width: 6px;
            height: 12px;
            border: solid white;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg);
        }

        /* Select All */
        .select-all-container {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            margin-bottom: 16px;
        }

        .select-all-label {
            color: var(--text-soft);
            font-size: var(--font-sm);
            font-weight: 500;
            user-select: none;
            cursor: pointer;
        }

        .selected-count {
            margin-left: auto;
            font-size: var(--font-sm);
            color: var(--primary-light);
            font-weight: 600;
        }

        /* Cart Item with Checkbox */
        .cart-item-wrapper {
            display: flex;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .cart-item.with-checkbox {
            flex: 1;
            display: flex;
            align-items: center;
            padding: 16px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            transition: all 0.3s ease;
        }

            .cart-item.with-checkbox:hover {
                background: rgba(255, 255, 255, 0.04);
                border-color: var(--border-focus);
            }

            .cart-item.with-checkbox.selected {
                background: rgba(168, 85, 247, 0.08);
                border-color: var(--primary);
            }

            .cart-item.with-checkbox .cart-item-product {
                flex: 1;
                min-width: 0;
            }

        /* Checkout Selected Button */
        .checkout-selected-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 16px;
            background: var(--gradient-primary);
            border: none;
            border-radius: var(--radius-lg);
            color: white;
            font-size: var(--font-md);
            font-weight: 700;
            font-family: var(--font-family);
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 32px var(--primary-glow);
            margin-top: 16px;
        }

            .checkout-selected-btn:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 12px 40px rgba(124, 58, 237, 0.6);
            }

            .checkout-selected-btn:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none;
            }

            .checkout-selected-btn svg {
                width: 20px;
                height: 20px;
            }

        /* Selected Summary */
        .selected-summary {
            background: rgba(168, 85, 247, 0.1);
            border: 1px solid rgba(168, 85, 247, 0.3);
            border-radius: var(--radius-lg);
            padding: 16px;
            margin-top: 16px;
        }

        .selected-summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .selected-summary-label {
            color: var(--text-soft);
            font-size: var(--font-sm);
        }

        .selected-summary-value {
            color: var(--primary-light);
            font-size: var(--font-lg);
            font-weight: 700;
        }

        /* Toast */
        .toast-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-width: 400px;
        }

        .toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            border-radius: 12px;
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .toast.toast-success {
                background: rgba(16, 185, 129, 0.15);
                border: 1px solid rgba(16, 185, 129, 0.3);
            }

            .toast.toast-error {
                background: rgba(239, 68, 68, 0.15);
                border: 1px solid rgba(239, 68, 68, 0.3);
            }

        .toast-icon {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

            .toast-icon svg {
                width: 100%;
                height: 100%;
            }

        .toast-success .toast-icon {
            color: #10b981;
        }

        .toast-error .toast-icon {
            color: #ef4444;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #fff;
        }

        .toast-message {
            font-size: 0.8125rem;
            color: rgba(255, 255, 255, 0.8);
        }

        .toast-close {
            width: 20px;
            height: 20px;
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }

            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        .toast.hiding {
            animation: slideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @@keyframes slideOut {
            from {
                opacity: 1;
                transform: translateX(0) scale(1);
            }

            to {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }
        }
    </style>
</head>
<body>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer">
        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="toast toast-success" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Success!</div>
                    <div class="toast-message">@successMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="toast toast-error" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Error!</div>
                    <div class="toast-message">@errorMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        }
    </div>

    <div class="landing-page cart-page">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>

        <!-- NAVBAR -->
        <nav class="landing-nav scrolled" id="navbar">
            <a class="nav-logo" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <path d="M16 10a4 4 0 01-8 0"></path>
                    </svg>
                </div>
                <span class="logo-text">E-<span>Commerce</span></span>
            </a>

            <div class="nav-actions">
                @if (!string.IsNullOrEmpty(userName))
                {
                    <a asp-controller="Carts" asp-action="Index" class="nav-btn nav-btn-ghost cart-nav-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        <span>Cart</span>
                        @if (Model != null && Model.TotalItems > 0)
                        {
                            <span class="cart-badge" id="navCartBadge">@Model.TotalItems</span>
                        }
                    </a>
                    <a asp-controller="Accounts" asp-action="UserProfile" asp-route-userName="@userName" class="nav-btn nav-btn-ghost">My Profile</a>
                    <a asp-controller="Accounts" asp-action="Logout" class="nav-btn nav-btn-ghost">Logout</a>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                    <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
                }
            </div>
        </nav>

        <div class="cart-container">
            @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
            {
                <!-- Empty Cart -->
                <div class="cart-items-section">
                    <div class="empty-cart">
                        <div class="empty-cart-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="9" cy="21" r="1"></circle>
                                <circle cx="20" cy="21" r="1"></circle>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                            </svg>
                        </div>
                        <h2>Your cart is empty</h2>
                        <p>Looks like you haven't added anything to your cart yet.</p>
                        <a asp-controller="Home" asp-action="Index">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Start Shopping
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="cart-header">
                    <h1>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        Shopping Cart
                    </h1>
                    <span class="cart-count" id="cartCount">@Model.TotalItems items</span>
                </div>

                <div class="cart-layout">
                    <!-- Cart Items -->
                    <div class="cart-items-section">
                        <!-- Select All -->
                        <div class="select-all-container">
                            <label class="custom-checkbox">
                                <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" />
                                <span class="checkmark"></span>
                            </label>
                            <label class="select-all-label" for="selectAll">Select All Items</label>
                            <span class="selected-count" id="selectedCount">0 selected</span>
                        </div>

                        <div class="cart-items-header">
                            <span>Product</span>
                            <span>Price</span>
                            <span>Quantity</span>
                            <span>Total</span>
                            <span></span>
                        </div>

                        @foreach (var item in Model.CartItems)
                        {
                            <div class="cart-item-wrapper">
                                <div class="cart-item-checkbox">
                                    <label class="custom-checkbox">
                                        <input type="checkbox" class="item-checkbox"
                                               data-cart-item-id="@item.CartItemId"
                                               data-product-price="@item.ProductPrice"
                                               data-quantity="@item.Quantity"
                                               onchange="updateSelection()" />
                                        <span class="checkmark"></span>
                                    </label>
                                </div>
                                <div class="cart-item with-checkbox" data-cart-item-id="@item.CartItemId" data-product-price="@item.ProductPrice" data-stock-quantity="@item.ProductStockQuantity">
                                    <div class="cart-item-product">
                                        <img src="@item.ImageSrc" alt="@item.ProductName" class="cart-item-image" />
                                        <div class="cart-item-info">
                                            <h3>@item.ProductName</h3>
                                            <p>@item.CategoryName</p>
                                            @if (item.ProductStockQuantity <= 5 && item.ProductStockQuantity > 0)
                                            {
                                                <p class="stock-warning">Only @item.ProductStockQuantity left in stock</p>
                                            }
                                        </div>
                                    </div>

                                    <div class="cart-item-price">$@item.ProductPrice.ToString("0.00")</div>

                                    <div class="quantity-controls">
                                        <button type="button" class="qty-btn qty-decrease" data-cart-item-id="@item.CartItemId" @(item.Quantity <= 1 ? "disabled" : "")>-</button>
                                        <span class="qty-value" id="qty-@item.CartItemId">@item.Quantity</span>
                                        <button type="button" class="qty-btn qty-increase" data-cart-item-id="@item.CartItemId" @(item.Quantity >= item.ProductStockQuantity ? "disabled" : "")>+</button>
                                    </div>

                                    <div class="cart-item-total" id="total-@item.CartItemId">$@item.TotalPrice.ToString("0.00")</div>

                                    <form asp-action="RemoveItem" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="remove-btn" title="Remove item">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Cart Summary -->
                    <div class="cart-summary">
                        <h2 class="summary-title">Order Summary</h2>

                        <div class="summary-row">
                            <span class="summary-label">Subtotal (<span id="subtotalItems">@Model.TotalItems</span> items)</span>
                            <span class="summary-value" id="subtotalPrice">$@Model.TotalPrice.ToString("0.00")</span>
                        </div>

                        <div class="summary-row">
                            <span class="summary-label">Shipping</span>
                            <span class="summary-value">Free</span>
                        </div>

                        <div class="summary-row">
                            <span class="summary-label">Tax</span>
                            <span class="summary-value">$0.00</span>
                        </div>

                        <div class="summary-row summary-total">
                            <span class="summary-label">Total</span>
                            <span class="summary-value" id="totalPrice">$@Model.TotalPrice.ToString("0.00")</span>
                        </div>

                        <!-- Selected Items Summary -->
                        <div class="selected-summary" id="selectedSummary" style="display: none;">
                            <div class="selected-summary-row">
                                <span class="selected-summary-label">Selected Items Total:</span>
                                <span class="selected-summary-value" id="selectedTotalPrice">$0.00</span>
                            </div>
                        </div>

                        <!-- Checkout Selected Button -->
                        <button type="button" class="checkout-selected-btn" id="checkoutSelectedBtn" onclick="checkoutSelected()" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            <span id="checkoutBtnText">Select items to checkout</span>
                        </button>

                        <a asp-controller="Home" asp-action="Index" class="continue-shopping">
                            ← Continue Shopping
                        </a>

                        <form asp-action="ClearCart" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="clear-cart-btn">Clear Cart</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- FOOTER -->
        <footer class="landing-footer">
            <p>&copy; 2025 E-Commerce. All rights reserved.</p>
        </footer>
    </div>

    @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
    {
        <script>
            // Cart data for client-side calculations
            const cartItems = {
                @foreach (var item in Model.CartItems)
                {
                        <text>'@item.CartItemId': { price: @item.ProductPrice, quantity: @item.Quantity, stock: @item.ProductStockQuantity },</text>
                }
            };

            // Format number as currency
            function formatCurrency(amount) {
                return '$' + amount.toFixed(2);
            }

            // Update all totals
            function updateCartTotals() {
                let totalItems = 0;
                let totalPrice = 0;

                for (const id in cartItems) {
                    const item = cartItems[id];
                    totalItems += item.quantity;
                    totalPrice += item.price * item.quantity;

                    // Update individual item total
                    const totalElement = document.getElementById('total-' + id);
                    if (totalElement) {
                        totalElement.textContent = formatCurrency(item.price * item.quantity);
                    }

                    // Update quantity display
                    const qtyElement = document.getElementById('qty-' + id);
                    if (qtyElement) {
                        qtyElement.textContent = item.quantity;
                    }
                }

                // Update cart count
                const cartCount = document.getElementById('cartCount');
                if (cartCount) {
                    cartCount.textContent = totalItems + ' item' + (totalItems !== 1 ? 's' : '');
                }

                // Update nav badge
                const navBadge = document.getElementById('navCartBadge');
                if (navBadge) {
                    navBadge.textContent = totalItems;
                }

                // Update summary
                const subtotalItems = document.getElementById('subtotalItems');
                if (subtotalItems) {
                    subtotalItems.textContent = totalItems;
                }

                const subtotalPrice = document.getElementById('subtotalPrice');
                if (subtotalPrice) {
                    subtotalPrice.textContent = formatCurrency(totalPrice);
                }

                const totalPriceEl = document.getElementById('totalPrice');
                if (totalPriceEl) {
                    totalPriceEl.textContent = formatCurrency(totalPrice);
                }
            }

            // Get anti-forgery token
            function getAntiForgeryToken() {
                const inputs = document.querySelectorAll('input[name="__RequestVerificationToken"]');
                return inputs.length > 0 ? inputs[0].value : '';
            }

            // Save to server (debounced)
            const saveTimeouts = {};
            function saveToServer(cartItemId, quantity) {
                if (saveTimeouts[cartItemId]) {
                    clearTimeout(saveTimeouts[cartItemId]);
                }

                saveTimeouts[cartItemId] = setTimeout(() => {
                    const formData = new FormData();
                    formData.append('cartItemId', cartItemId);
                    formData.append('quantity', quantity);
                    formData.append('__RequestVerificationToken', getAntiForgeryToken());

                    fetch('/Carts/UpdateQuantity', {
                        method: 'POST',
                        body: formData
                    }).then(response => response.json())
                      .then(data => {
                          if (!data.success) {
                              console.error('Failed to update:', data.message);
                          }
                      })
                      .catch(error => {
                          console.error('Failed to update cart:', error);
                      });
                }, 500);
            }

            // Initialize quantity buttons
            document.querySelectorAll('.qty-increase').forEach(btn => {
                btn.addEventListener('click', function() {
                    const cartItemId = this.getAttribute('data-cart-item-id');
                    const item = cartItems[cartItemId];
                    if (!item) return;

                    if (item.quantity < item.stock) {
                        item.quantity++;
                        updateCartTotals();
                        updateButtonStates(cartItemId);
                        updateSelection();
                        saveToServer(cartItemId, item.quantity);
                    }
                });
            });

            document.querySelectorAll('.qty-decrease').forEach(btn => {
                btn.addEventListener('click', function() {
                    const cartItemId = this.getAttribute('data-cart-item-id');
                    const item = cartItems[cartItemId];
                    if (!item) return;

                    if (item.quantity > 1) {
                        item.quantity--;
                        updateCartTotals();
                        updateButtonStates(cartItemId);
                        updateSelection();
                        saveToServer(cartItemId, item.quantity);
                    }
                });
            });

            // Update button states (enable/disable)
            function updateButtonStates(cartItemId) {
                const item = cartItems[cartItemId];
                if (!item) return;

                const cartItem = document.querySelector('[data-cart-item-id="' + cartItemId + '"]');
                if (!cartItem) return;

                const decreaseBtn = cartItem.querySelector('.qty-decrease');
                const increaseBtn = cartItem.querySelector('.qty-increase');

                if (decreaseBtn) {
                    decreaseBtn.disabled = item.quantity <= 1;
                }

                if (increaseBtn) {
                    increaseBtn.disabled = item.quantity >= item.stock;
                }
            }

            // ===== SELECTION LOGIC =====

            // Toggle select all
            function toggleSelectAll(checkbox) {
                const itemCheckboxes = document.querySelectorAll('.item-checkbox');
                itemCheckboxes.forEach(cb => {
                    cb.checked = checkbox.checked;
                });
                updateSelection();
            }

            // Update selection state
            function updateSelection() {
                const itemCheckboxes = document.querySelectorAll('.item-checkbox');
                const selectedItems = [];
                let selectedTotal = 0;
                let selectedCount = 0;

                itemCheckboxes.forEach(cb => {
                    const cartItemId = cb.getAttribute('data-cart-item-id');
                    const cartItem = document.querySelector(`.cart-item.with-checkbox[data-cart-item-id="${cartItemId}"]`);

                    if (cb.checked) {
                        const item = cartItems[cartItemId];
                        if (item) {
                            selectedItems.push(cartItemId);
                            selectedTotal += item.price * item.quantity;
                            selectedCount += item.quantity;
                        }
                        if (cartItem) cartItem.classList.add('selected');
                    } else {
                        if (cartItem) cartItem.classList.remove('selected');
                    }
                });

                // Update selected count
                const selectedCountEl = document.getElementById('selectedCount');
                if (selectedCountEl) {
                    selectedCountEl.textContent = `${selectedCount} selected`;
                }

                // Update select all checkbox
                const selectAllCheckbox = document.getElementById('selectAll');
                if (selectAllCheckbox) {
                    selectAllCheckbox.checked = itemCheckboxes.length > 0 &&
                        Array.from(itemCheckboxes).every(cb => cb.checked);
                }

                // Update selected summary
                const selectedSummary = document.getElementById('selectedSummary');
                const selectedTotalPrice = document.getElementById('selectedTotalPrice');
                const checkoutBtn = document.getElementById('checkoutSelectedBtn');
                const checkoutBtnText = document.getElementById('checkoutBtnText');

                if (selectedItems.length > 0) {
                    selectedSummary.style.display = 'block';
                    selectedTotalPrice.textContent = formatCurrency(selectedTotal);
                    checkoutBtn.disabled = false;
                    checkoutBtnText.textContent = `Checkout ${selectedItems.length} item${selectedItems.length > 1 ? 's' : ''}`;
                } else {
                    selectedSummary.style.display = 'none';
                    checkoutBtn.disabled = true;
                    checkoutBtnText.textContent = 'Select items to checkout';
                }

                // Store selected items
                window.selectedCartItems = selectedItems;
            }

            // Checkout selected items
            function checkoutSelected() {
                if (!window.selectedCartItems || window.selectedCartItems.length === 0) {
                    alert('Please select at least one item to checkout.');
                    return;
                }

                const selectedItemsStr = window.selectedCartItems.join(',');
                window.location.href = `/Orders/CheckoutCart?selectedItems=${encodeURIComponent(selectedItemsStr)}`;
            }
        </script>
    }

    <script>
        // Toast functions
        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('hiding');
            setTimeout(() => toast.remove(), 300);
        }

        document.querySelectorAll('.toast').forEach(toast => {
            setTimeout(() => {
                if (toast && !toast.classList.contains('hiding')) {
                    toast.classList.add('hiding');
                    setTimeout(() => toast.remove(), 300);
                }
            }, 5000);
        });
    </script>
</body>
</html>