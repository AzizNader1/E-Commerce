@model E_Commerce.MVC.DTOs.OrderDTOs.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = null;
    var userName = (string?)TempData["UserName"];
    var userRole = (string?)TempData["UserRole"];

    var imgSrc = Model.Product?.ProductImage != null && Model.Product.ProductImage.Length > 0
        ? $"data:{Model.Product.ProductImageContentType};base64,{Convert.ToBase64String(Model.Product.ProductImage)}"
        : "https://placehold.co/400x300/1e1b4b/a855f7?text=No+Image";

    var quantity = Model.OrderQuantity > 0 ? Model.OrderQuantity : 1;
    var unitPrice = Model.Product?.ProductPrice ?? 0;
    var totalPrice = Model.TotalPrice > 0 ? Model.TotalPrice : (unitPrice * quantity);
    var maxStock = Model.Product?.ProductStockQuantity ?? 1;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout | E-Commerce</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/shared/home.css" />
    <link rel="stylesheet" href="~/css/order/orders.css" />
    <style>
        .quantity-selector-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: var(--space-md) 0;
            border-bottom: 1px solid var(--border-glass);
        }

        .quantity-label {
            color: var(--text-muted);
            font-size: var(--font-base);
        }

        .quantity-selector {
            display: flex;
            align-items: center;
            gap: 2px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-glass);
            overflow: hidden;
        }

        .qty-btn {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            color: var(--text-soft);
            cursor: pointer;
            transition: all var(--duration) ease;
            font-size: 1.2rem;
            font-weight: 600;
        }

        .qty-btn:hover:not(:disabled) {
            background: rgba(168, 85, 247, 0.15);
            color: var(--primary-light);
        }

        .qty-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .qty-input {
            width: 60px;
            height: 40px;
            text-align: center;
            background: transparent;
            border: none;
            color: var(--text-white);
            font-size: var(--font-base);
            font-weight: 600;
            font-family: var(--font-family);
        }

        .qty-input:focus {
            outline: none;
        }

        .stock-warning {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: var(--space-sm) var(--space-md);
            background: rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(251, 191, 36, 0.2);
            border-radius: var(--radius-md);
            margin-top: var(--space-sm);
            font-size: var(--font-sm);
            color: #fbbf24;
        }

        .stock-warning svg {
            width: 16px;
            height: 16px;
        }

        .checkout-page {
            min-height: 100vh;
            padding-top: 100px;
            padding-bottom: 60px;
            position: relative;
            z-index: 1;
        }

        .checkout-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 var(--space-xl);
        }

        .checkout-header {
            text-align: center;
            margin-bottom: var(--space-2xl);
        }

        .checkout-header h1 {
            font-size: var(--font-3xl);
            font-weight: 800;
            color: var(--text-white);
            margin-bottom: var(--space-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .checkout-header h1 svg {
            width: 36px;
            height: 36px;
            color: var(--primary-light);
        }

        .checkout-header p {
            color: var(--text-muted);
            font-size: var(--font-base);
        }

        .checkout-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: var(--space-xl);
            align-items: start;
        }

        .checkout-card {
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-2xl);
            padding: var(--space-xl);
            margin-bottom: var(--space-lg);
            position: relative;
            overflow: hidden;
        }

        .checkout-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--gradient-primary);
            opacity: 0;
            transition: opacity var(--duration) ease;
        }

        .checkout-card:hover::before {
            opacity: 1;
        }

        .checkout-card-title {
            font-size: var(--font-lg);
            font-weight: 700;
            color: var(--text-white);
            margin-bottom: var(--space-lg);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .checkout-card-title svg {
            width: 22px;
            height: 22px;
            color: var(--primary-light);
        }

        .user-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-md);
        }

        .info-item {
            padding: var(--space-md);
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-glass);
        }

        .info-item.full-width {
            grid-column: 1 / -1;
        }

        .info-label {
            font-size: var(--font-xs);
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .info-value {
            font-size: var(--font-base);
            color: var(--text-white);
            font-weight: 500;
        }

        .checkout-product {
            display: flex;
            gap: var(--space-lg);
            padding: var(--space-lg);
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-xl);
            border: 1px solid var(--border-glass);
        }

        .checkout-product-image {
            width: 120px;
            height: 120px;
            border-radius: var(--radius-lg);
            object-fit: cover;
            flex-shrink: 0;
        }

        .checkout-product-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .checkout-product-category {
            font-size: var(--font-xs);
            color: var(--primary-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .checkout-product-name {
            font-size: var(--font-lg);
            font-weight: 700;
            color: var(--text-white);
            margin-bottom: var(--space-sm);
        }

        .checkout-product-description {
            font-size: var(--font-sm);
            color: var(--text-muted);
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: var(--space-sm);
        }

        .checkout-product-price {
            font-size: var(--font-xl);
            font-weight: 800;
            color: var(--primary-light);
        }

        .order-summary-card {
            position: sticky;
            top: 100px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-md) 0;
            border-bottom: 1px solid var(--border-glass);
        }

        .summary-row:last-of-type {
            border-bottom: none;
        }

        .summary-label {
            color: var(--text-muted);
            font-size: var(--font-base);
        }

        .summary-value {
            color: var(--text-white);
            font-weight: 600;
            font-size: var(--font-base);
        }

        .summary-total {
            margin-top: var(--space-md);
            padding-top: var(--space-md);
            border-top: 2px solid var(--border-glass);
        }

        .summary-total .summary-label {
            font-size: var(--font-lg);
            font-weight: 700;
            color: var(--text-white);
        }

        .summary-total .summary-value {
            font-size: var(--font-2xl);
            font-weight: 800;
            color: var(--primary-light);
        }

        .checkout-features {
            margin-top: var(--space-lg);
            padding-top: var(--space-lg);
            border-top: 1px solid var(--border-glass);
        }

        .checkout-feature {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: var(--space-sm) 0;
            color: var(--text-muted);
            font-size: var(--font-sm);
        }

        .checkout-feature svg {
            width: 18px;
            height: 18px;
            color: var(--success);
        }

        .checkout-actions {
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
            margin-top: var(--space-xl);
        }

        .btn-place-order {
            width: 100%;
            padding: 18px 32px;
            background: var(--gradient-primary);
            border: none;
            border-radius: var(--radius-lg);
            color: var(--text-white);
            font-size: var(--font-md);
            font-weight: 700;
            font-family: var(--font-family);
            cursor: pointer;
            transition: all var(--duration) ease;
            box-shadow: 0 8px 32px var(--primary-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-place-order:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(124, 58, 237, 0.6);
        }

        .btn-place-order svg {
            width: 20px;
            height: 20px;
        }

        .btn-cancel-order {
            width: 100%;
            padding: 14px 32px;
            background: transparent;
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            color: var(--text-soft);
            font-size: var(--font-sm);
            font-weight: 600;
            font-family: var(--font-family);
            text-decoration: none;
            text-align: center;
            transition: all var(--duration) ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-cancel-order:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
            color: #ef4444;
        }

        .toast-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-width: 400px;
        }

        .toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            border-radius: 12px;
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            transform-origin: top right;
            position: relative;
            overflow: hidden;
        }

        .toast.toast-error {
            background: rgba(239, 68, 68, 0.15);
            border-color: rgba(239, 68, 68, 0.3);
        }

        .toast-icon {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

        .toast-icon svg {
            width: 100%;
            height: 100%;
        }

        .toast-success .toast-icon {
            color: #10b981;
        }

        .toast-error .toast-icon {
            color: #ef4444;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 2px;
        }

        .toast-message {
            font-size: 0.8125rem;
            color: rgba(255, 255, 255, 0.8);
        }

        .toast-close {
            width: 20px;
            height: 20px;
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .toast-close:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.1);
        }

        .toast-close svg {
            width: 16px;
            height: 16px;
        }

        .toast-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: rgba(16, 185, 129, 0.6);
            border-radius: 0 0 12px 12px;
            animation: progress 5s linear forwards;
        }

        .toast-error .toast-progress {
            background: rgba(239, 68, 68, 0.6);
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }
            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        @@keyframes slideOut {
            from {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
            to {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }
        }

        @@keyframes progress {
            from {
                width: 100%;
            }
            to {
                width: 0%;
            }
        }

        .toast.hiding {
            animation: slideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

       @@media (max-width: 900px) {
            .checkout-grid {
                grid-template-columns: 1fr;
            }

            .order-summary-card {
                position: static;
            }
        }

        @@media (max-width: 576px) {
            .checkout-container {
                padding: 0 var(--space-md);
            }

            .checkout-header h1 {
                font-size: var(--font-2xl);
            }

            .user-info-grid {
                grid-template-columns: 1fr;
            }

            .checkout-product {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }

            .checkout-product-image {
                width: 150px;
                height: 150px;
            }

            .toast-container {
                right: 12px;
                left: 12px;
                max-width: none;
            }
        }
    </style>
</head>
<body>

    <div class="toast-container" id="toastContainer">
        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="toast toast-success" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Success!</div>
                    <div class="toast-message">@successMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="toast toast-error" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Error!</div>
                    <div class="toast-message">@errorMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }
    </div>

    <div class="landing-page">

        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>

        <nav class="landing-nav scrolled" id="navbar">
            <a class="nav-logo" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 01-8 0" />
                    </svg>
                </div>
                <span class="logo-text">E-<span>Commerce</span></span>
            </a>

            <div class="nav-actions">
                @if (userName != "")
                {
                    <a asp-controller="Carts" asp-action="Index" class="nav-btn nav-btn-ghost">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        Cart
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="nav-btn nav-btn-ghost">My Orders</a>
                    <a asp-controller="Accounts" asp-action="Logout" class="nav-btn nav-btn-ghost">Logout</a>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                    <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
                }
            </div>
        </nav>

        <div class="checkout-page">
            <div class="checkout-container">

                <div class="checkout-header">
                    <h1>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        Checkout
                    </h1>
                    <p>Review your order details and confirm your purchase</p>
                </div>

                @if (Model.User != null && Model.Product != null)
                {
                    <div class="checkout-grid">

                        <div class="checkout-left">

                            <div class="checkout-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                    Shipping Information
                                </div>

                                <div class="user-info-grid">
                                    <div class="info-item">
                                        <div class="info-label">Full Name</div>
                                        <div class="info-value">@Model.User.UserFullName</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Username</div>
                                        <div class="info-value">@Model.User.UserName</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Email Address</div>
                                        <div class="info-value">@Model.User.UserEmail</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Phone Number</div>
                                        <div class="info-value">@(Model.User.UserPhoneNumber ?? "Not provided")</div>
                                    </div>
                                    <div class="info-item full-width">
                                        <div class="info-label">Shipping Address</div>
                                        <div class="info-value">@Model.User.UserAddress</div>
                                    </div>
                                </div>
                            </div>

                            <div class="checkout-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                                        <line x1="3" y1="6" x2="21" y2="6"></line>
                                        <path d="M16 10a4 4 0 01-8 0"></path>
                                    </svg>
                                    Product Details
                                </div>

                                <div class="checkout-product">
                                    <img src="@imgSrc" alt="@Model.Product.ProductName" class="checkout-product-image" />
                                    <div class="checkout-product-info">
                                        <div class="checkout-product-category">@Model.Product.CategoryName?.ToString()</div>
                                        <div class="checkout-product-name">@Model.Product.ProductName</div>
                                        <div class="checkout-product-description">@Model.Product.ProductDescription</div>
                                        <div class="checkout-product-price">$@Model.Product!.ProductPrice.ToString("0.00")</div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="checkout-right">
                            <div class="checkout-card order-summary-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="8" y1="6" x2="21" y2="6"></line>
                                        <line x1="8" y1="12" x2="21" y2="12"></line>
                                        <line x1="8" y1="18" x2="21" y2="18"></line>
                                        <line x1="3" y1="6" x2="3.01" y2="6"></line>
                                        <line x1="3" y1="12" x2="3.01" y2="12"></line>
                                        <line x1="3" y1="18" x2="3.01" y2="18"></line>
                                    </svg>
                                    Order Summary
                                </div>

                                <div class="summary-row">
                                    <span class="summary-label">Product</span>
                                    <span class="summary-value">@Model.Product.ProductName</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Category</span>
                                    <span class="summary-value">@Model.Product.CategoryName?.ToString()</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Unit Price</span>
                                    <span class="summary-value">$@unitPrice.ToString("0.00")</span>
                                </div>

                                <div class="quantity-selector-wrapper">
                                    <span class="quantity-label">Quantity</span>
                                    <div class="quantity-selector">
                                        <button type="button" class="qty-btn" id="decrementBtn" onclick="updateQuantity(-1)">−</button>
                                        <input type="number" name="Quantity" id="quantityInput" value="@quantity" min="1" max="@maxStock" class="qty-input" readonly />
                                        <button type="button" class="qty-btn" id="incrementBtn" onclick="updateQuantity(1)">+</button>
                                    </div>
                                </div>
                                @if (maxStock <= 5 && maxStock > 0)
                                {
                                    <div class="stock-warning">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <line x1="12" y1="8" x2="12" y2="12"></line>
                                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                        </svg>
                                        Only @maxStock items in stock!
                                    </div>
                                }

                                <div class="summary-row">
                                    <span class="summary-label">Subtotal</span>
                                    <span class="summary-value" id="subtotalValue">$@(unitPrice * quantity).ToString("0.00")</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Shipping</span>
                                    <span class="summary-value" style="color: var(--success);">Free</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Tax (0%)</span>
                                    <span class="summary-value">$0.00</span>
                                </div>

                                <div class="summary-row summary-total">
                                    <span class="summary-label">Total</span>
                                    <span class="summary-value" id="totalValue">$@totalPrice.ToString("0.00")</span>
                                </div>

                                <div class="checkout-features">
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>Secure payment processing</span>
                                    </div>
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>Free shipping on all orders</span>
                                    </div>
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>30-day return policy</span>
                                    </div>
                                </div>

                                <form asp-controller="Orders" asp-action="PlaceOrder" method="post">
                                    <input type="hidden" name="User.UserId" value="@Model.User.UserId" />
                                    <input type="hidden" name="User.UserName" value="@Model.User.UserName" />
                                    <input type="hidden" name="User.UserEmail" value="@Model.User.UserEmail" />
                                    <input type="hidden" name="User.UserPassword" value="@Model.User.UserPassword" />
                                    <input type="hidden" name="User.UserFullName" value="@Model.User.UserFullName" />
                                    <input type="hidden" name="User.UserAddress" value="@Model.User.UserAddress" />
                                    <input type="hidden" name="User.UserPhoneNumber" value="@Model.User.UserPhoneNumber" />

                                    <input type="hidden" name="Product.ProductId" value="@Model.Product.ProductId" />
                                    <input type="hidden" name="Product.ProductName" value="@Model.Product.ProductName" />
                                    <input type="hidden" name="Product.ProductDescription" value="@Model.Product.ProductDescription" />
                                    <input type="hidden" name="Product.ProductPrice" value="@Model.Product.ProductPrice" />
                                    <input type="hidden" name="Product.ProductStockQuantity" value="@Model.Product.ProductStockQuantity" />
                                    <input type="hidden" name="Product.CategoryId" value="@Model.Product.CategoryId" />

                                    <input type="hidden" name="TotalPrice" id="totalPriceInput" value="@totalPrice" />
                                    <input type="hidden" name="OrderQuantity" id="quantityHiddenInput" value="@quantity" />

                                    <div class="checkout-actions">
                                        <button type="submit" class="btn-place-order" id="placeOrderBtn">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                            </svg>
                                            Place Order
                                        </button>
                                        <a asp-controller="Home" asp-action="Index" class="btn-cancel-order">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                            Cancel and Continue Shopping
                                        </a>
                                    </div>
                                </form>

                            </div>
                        </div>

                    </div>
                }
                else
                {
                    <div class="checkout-card" style="text-align: center; padding: var(--space-3xl);">
                        <div class="empty-icon" style="margin: 0 auto var(--space-lg);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="8" x2="12" y2="12"></line>
                                <line x1="12" y1="16" x2="12.01" y2="16"></line>
                            </svg>
                        </div>
                        <h2 style="color: var(--text-white); margin-bottom: var(--space-sm);">Unable to load checkout</h2>
                        <p style="color: var(--text-muted); margin-bottom: var(--space-xl);">There was a problem loading your checkout information. Please try again.</p>
                        <a asp-controller="Home" asp-action="Index" class="btn-hero btn-hero-primary" style="display: inline-flex;">
                            Back to Home
                        </a>
                    </div>
                }

            </div>
        </div>

        <footer class="landing-footer">
            <p>&copy; 2025 E-Commerce. All rights reserved.</p>
            <p>Built with <a href="#">ASP.NET Core</a></p>
        </footer>

    </div>

    <script>
        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('hiding');
            setTimeout(() => {
                toast.remove();
            }, 300);
        }

        document.querySelectorAll('.toast').forEach(toast => {
            setTimeout(() => {
                if (toast && !toast.classList.contains('hiding')) {
                    toast.classList.add('hiding');
                    setTimeout(() => {
                        toast.remove();
                    }, 300);
                }
            }, 5000);
        });

        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 40);
        });

        const unitPrice = @unitPrice;
        const maxStock = @maxStock;

        function updateQuantity(change) {
            const input = document.getElementById('quantityInput');
            const hiddenInput = document.getElementById('quantityHiddenInput');
            let currentValue = parseInt(input.value) || 1;
            let newValue = currentValue + change;

            if (newValue < 1) newValue = 1;
            if (newValue > maxStock) newValue = maxStock;

            input.value = newValue;
            hiddenInput.value = newValue;

            updatePrices(newValue);
            updateButtons(newValue);
        }

        function updatePrices(quantity) {
            const subtotal = unitPrice * quantity;
            const total = subtotal;

            document.getElementById('subtotalValue').textContent = '$' + subtotal.toFixed(2);
            document.getElementById('totalValue').textContent = '$' + total.toFixed(2);
            document.getElementById('totalPriceInput').value = total;
        }

        function updateButtons(quantity) {
            document.getElementById('decrementBtn').disabled = quantity <= 1;
            document.getElementById('incrementBtn').disabled = quantity >= maxStock;
        }

        updateButtons(parseInt(document.getElementById('quantityInput').value) || 1);
    </script>
</body>
</html>