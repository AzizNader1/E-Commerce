@model E_Commerce.MVC.DTOs.CheckoutDTOs.CartCheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = null;
    var userName = (string?)TempData["UserName"];
    var userRole = (string?)TempData["UserRole"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout | E-Commerce</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/shared/home.css" />
    <style>
        .checkout-page {
            min-height: 100vh;
            padding-top: 100px;
            padding-bottom: 60px;
            position: relative;
            z-index: 1;
        }

        .checkout-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 var(--space-xl);
        }

        .checkout-header {
            text-align: center;
            margin-bottom: var(--space-2xl);
        }

        .checkout-header h1 {
            font-size: var(--font-3xl);
            font-weight: 800;
            color: var(--text-white);
            margin-bottom: var(--space-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .checkout-header h1 svg {
            width: 36px;
            height: 36px;
            color: var(--primary-light);
        }

        .checkout-header p {
            color: var(--text-muted);
            font-size: var(--font-base);
        }

        .checkout-grid {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: var(--space-xl);
            align-items: start;
        }

        .checkout-card {
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-2xl);
            padding: var(--space-xl);
            margin-bottom: var(--space-lg);
            position: relative;
            overflow: hidden;
        }

        .checkout-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--gradient-primary);
            opacity: 0;
            transition: opacity var(--duration) ease;
        }

        .checkout-card:hover::before {
            opacity: 1;
        }

        .checkout-card-title {
            font-size: var(--font-lg);
            font-weight: 700;
            color: var(--text-white);
            margin-bottom: var(--space-lg);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .checkout-card-title svg {
            width: 22px;
            height: 22px;
            color: var(--primary-light);
        }

        .user-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-md);
        }

        .info-item {
            padding: var(--space-md);
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-glass);
        }

        .info-item.full-width {
            grid-column: 1 / -1;
        }

        .info-label {
            font-size: var(--font-xs);
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .info-value {
            font-size: var(--font-base);
            color: var(--text-white);
            font-weight: 500;
        }

        .checkout-items-list {
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
        }

        .checkout-item {
            display: flex;
            gap: var(--space-md);
            padding: var(--space-md);
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-glass);
            transition: all var(--duration) ease;
        }

        .checkout-item:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--border-focus);
        }

        .checkout-item-image {
            width: 80px;
            height: 80px;
            border-radius: var(--radius-md);
            object-fit: cover;
            flex-shrink: 0;
        }

        .checkout-item-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }

        .checkout-item-name {
            font-size: var(--font-base);
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .checkout-item-category {
            font-size: var(--font-xs);
            color: var(--primary-light);
            margin-bottom: 4px;
        }

        .checkout-item-qty {
            font-size: var(--font-xs);
            color: var(--text-muted);
        }

        .checkout-item-price {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            justify-content: center;
            flex-shrink: 0;
        }

        .checkout-item-unit-price {
            font-size: var(--font-xs);
            color: var(--text-muted);
        }

        .checkout-item-total {
            font-size: var(--font-base);
            font-weight: 700;
            color: var(--primary-light);
        }

        .order-summary-card {
            position: sticky;
            top: 100px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-md) 0;
            border-bottom: 1px solid var(--border-glass);
        }

        .summary-row:last-of-type {
            border-bottom: none;
        }

        .summary-label {
            color: var(--text-muted);
            font-size: var(--font-base);
        }

        .summary-value {
            color: var(--text-white);
            font-weight: 600;
            font-size: var(--font-base);
        }

        .summary-total {
            margin-top: var(--space-md);
            padding-top: var(--space-md);
            border-top: 2px solid var(--border-glass);
        }

        .summary-total .summary-label {
            font-size: var(--font-lg);
            font-weight: 700;
            color: var(--text-white);
        }

        .summary-total .summary-value {
            font-size: var(--font-2xl);
            font-weight: 800;
            color: var(--primary-light);
        }

        .items-count-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            background: rgba(168, 85, 247, 0.15);
            border: 1px solid rgba(168, 85, 247, 0.3);
            border-radius: var(--radius-full);
            font-size: var(--font-sm);
            color: var(--primary-light);
            margin-left: auto;
        }

        .checkout-features {
            margin-top: var(--space-lg);
            padding-top: var(--space-lg);
            border-top: 1px solid var(--border-glass);
        }

        .checkout-feature {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: var(--space-sm) 0;
            color: var(--text-muted);
            font-size: var(--font-sm);
        }

        .checkout-feature svg {
            width: 18px;
            height: 18px;
            color: var(--success);
        }

        .checkout-actions {
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
            margin-top: var(--space-xl);
        }

        .btn-place-order {
            width: 100%;
            padding: 18px 32px;
            background: var(--gradient-primary);
            border: none;
            border-radius: var(--radius-lg);
            color: var(--text-white);
            font-size: var(--font-md);
            font-weight: 700;
            font-family: var(--font-family);
            cursor: pointer;
            transition: all var(--duration) ease;
            box-shadow: 0 8px 32px var(--primary-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-place-order:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(124, 58, 237, 0.6);
        }

        .btn-place-order svg {
            width: 20px;
            height: 20px;
        }

        .btn-cancel-order {
            width: 100%;
            padding: 14px 32px;
            background: transparent;
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            color: var(--text-soft);
            font-size: var(--font-sm);
            font-weight: 600;
            font-family: var(--font-family);
            text-decoration: none;
            text-align: center;
            transition: all var(--duration) ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-cancel-order:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
            color: #ef4444;
        }

        @@media (max-width: 900px) {
            .checkout-grid {
                grid-template-columns: 1fr;
            }

            .order-summary-card {
                position: static;
            }
        }

        @@media (max-width: 576px) {
            .checkout-container {
                padding: 0 var(--space-md);
            }

            .checkout-header h1 {
                font-size: var(--font-2xl);
            }

            .user-info-grid {
                grid-template-columns: 1fr;
            }

            .checkout-item {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }

            .checkout-item-image {
                width: 100px;
                height: 100px;
            }

            .checkout-item-price {
                align-items: center;
            }
        }
    </style>
</head>
<body>

    <div class="landing-page">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <!-- NAVBAR -->
        <nav class="landing-nav scrolled" id="navbar">
            <a class="nav-logo" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 01-8 0" />
                    </svg>
                </div>
                <span class="logo-text">E-<span>Commerce</span></span>
            </a>

            <div class="nav-actions">
                @if (!string.IsNullOrEmpty(userName))
                {
                    <a asp-controller="Carts" asp-action="Index" class="nav-btn nav-btn-ghost">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        Cart
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="nav-btn nav-btn-ghost">My Orders</a>
                    <a asp-controller="Accounts" asp-action="Logout" class="nav-btn nav-btn-ghost">Logout</a>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                    <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
                }
            </div>
        </nav>

        <!-- CHECKOUT CONTENT -->
        <div class="checkout-page">
            <div class="checkout-container">

                <!-- Header -->
                <div class="checkout-header">
                    <h1>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        Cart Checkout
                    </h1>
                    <p>Review your selected items and confirm your order</p>
                </div>

                @if (Model.User != null && Model.SelectedItems != null && Model.SelectedItems.Any())
                {
                    <div class="checkout-grid">

                        <!-- Left Column -->
                        <div class="checkout-left">

                            <!-- User Information Card -->
                            <div class="checkout-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                    Shipping Information
                                </div>

                                <div class="user-info-grid">
                                    <div class="info-item">
                                        <div class="info-label">Full Name</div>
                                        <div class="info-value">@Model.User.UserFullName</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Username</div>
                                        <div class="info-value">@Model.User.UserName</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Email Address</div>
                                        <div class="info-value">@Model.User.UserEmail</div>
                                    </div>
                                    <div class="info-item">
                                        <div class="info-label">Phone Number</div>
                                        <div class="info-value">@(Model.User.UserPhoneNumber ?? "Not provided")</div>
                                    </div>
                                    <div class="info-item full-width">
                                        <div class="info-label">Shipping Address</div>
                                        <div class="info-value">@Model.User.UserAddress</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Selected Items Card -->
                            <div class="checkout-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                                        <line x1="3" y1="6" x2="21" y2="6"></line>
                                        <path d="M16 10a4 4 0 01-8 0"></path>
                                    </svg>
                                    Selected Items
                                    <span class="items-count-badge">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="9" cy="21" r="1"></circle>
                                            <circle cx="20" cy="21" r="1"></circle>
                                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                                        </svg>
                                        @Model.SelectedItems.Count items
                                    </span>
                                </div>

                                <div class="checkout-items-list">
                                    @foreach (var item in Model.SelectedItems)
                                    {
                                        <div class="checkout-item">
                                            <img src="@item.ImageSrc" alt="@item.ProductName" class="checkout-item-image" />
                                            <div class="checkout-item-info">
                                                <div class="checkout-item-name">@item.ProductName</div>
                                                @if (!string.IsNullOrEmpty(item.CategoryName))
                                                {
                                                    <div class="checkout-item-category">@item.CategoryName</div>
                                                }
                                                <div class="checkout-item-qty">Qty: @item.Quantity</div>
                                            </div>
                                            <div class="checkout-item-price">
                                                <div class="checkout-item-unit-price">$@item.ProductPrice.ToString("0.00") each</div>
                                                <div class="checkout-item-total">$@item.TotalPrice.ToString("0.00")</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>

                        <!-- Right Column - Order Summary -->
                        <div class="checkout-right">
                            <div class="checkout-card order-summary-card">
                                <div class="checkout-card-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="8" y1="6" x2="21" y2="6"></line>
                                        <line x1="8" y1="12" x2="21" y2="12"></line>
                                        <line x1="8" y1="18" x2="21" y2="18"></line>
                                        <line x1="3" y1="6" x2="3.01" y2="6"></line>
                                        <line x1="3" y1="12" x2="3.01" y2="12"></line>
                                        <line x1="3" y1="18" x2="3.01" y2="18"></line>
                                    </svg>
                                    Order Summary
                                </div>

                                <div class="summary-row">
                                    <span class="summary-label">Items (@Model.TotalItems)</span>
                                    <span class="summary-value">$@Model.Subtotal.ToString("0.00")</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Shipping</span>
                                    <span class="summary-value" style="color: var(--success);">Free</span>
                                </div>
                                <div class="summary-row">
                                    <span class="summary-label">Tax</span>
                                    <span class="summary-value">$0.00</span>
                                </div>

                                <div class="summary-row summary-total">
                                    <span class="summary-label">Total</span>
                                    <span class="summary-value">$@Model.TotalPrice.ToString("0.00")</span>
                                </div>

                                <!-- Features -->
                                <div class="checkout-features">
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>Secure payment processing</span>
                                    </div>
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>Free shipping on all orders</span>
                                    </div>
                                    <div class="checkout-feature">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>30-day return policy</span>
                                    </div>
                                </div>

                                <!-- Action Buttons -->
                                <form asp-controller="Orders" asp-action="PlaceOrderFromCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="checkout-actions">
                                        <button type="submit" class="btn-place-order">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                            </svg>
                                            Place Order
                                        </button>
                                        <a asp-controller="Carts" asp-action="Index" class="btn-cancel-order">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                            Cancel and Return to Cart
                                        </a>
                                    </div>
                                </form>

                            </div>
                        </div>

                    </div>
                }
                else
                {
                    <div class="checkout-card" style="text-align: center; padding: var(--space-3xl);">
                        <h2 style="color: var(--text-white); margin-bottom: var(--space-sm);">Unable to load checkout</h2>
                        <p style="color: var(--text-muted); margin-bottom: var(--space-xl);">There was a problem loading your checkout information. Please try again.</p>
                        <a asp-controller="Carts" asp-action="Index" class="btn-hero btn-hero-primary" style="display: inline-flex;">
                            Back to Cart
                        </a>
                    </div>
                }

            </div>
        </div>

        <!-- FOOTER -->
        <footer class="landing-footer">
            <p>&copy; 2025 E-Commerce. All rights reserved.</p>
        </footer>

    </div>

    <script>
        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('hiding');
            setTimeout(() => toast.remove(), 300);
        }
    </script>
</body>
</html>