@model IEnumerable<E_Commerce.MVC.DTOs.ProductDTOs.ProductDto>

@{
    ViewData["Title"] = "Home";
    Layout = null;
    
    // We can group categories from the products list to ensure we only show categories that have products, or just statically list them
    var allCategories = Enum.GetValues(typeof(E_Commerce.MVC.Models.CategoriesCollections))
                            .Cast<E_Commerce.MVC.Models.CategoriesCollections>()
                            .ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-Commerce — Shop the Future</title>
    <meta name="description" content="Discover premium products with a seamless shopping experience. Fast delivery, secure payments, and unbeatable prices." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Design System + Home CSS -->
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/home.css" />
</head>
<body>

<div class="landing-page">

    <!-- Background Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- Particles -->
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>

    <!-- ═══════════ NAVBAR ═══════════ -->
    <nav class="landing-nav" id="navbar">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            <div class="logo-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 01-8 0" />
                </svg>
            </div>
            <span class="logo-text">E-<span>Commerce</span></span>
        </a>

        <div class="nav-actions">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                var username = User.Identity.Name ?? "User";
                var initial = username.Substring(0, 1).ToUpper();

                <div class="user-dropdown-wrapper">
                    <button class="user-profile-btn">
                        <div class="user-avatar">@initial</div>
                        <span class="user-name">@username</span>
                        <svg class="chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </button>
                    <div class="user-dropdown-menu">
                        <div class="dropdown-header">
                            <div class="user-avatar large">@initial</div>
                            <div class="user-info">
                                <strong>@username</strong>
                                <span>Verified Member</span>
                            </div>
                        </div>
                        <hr class="dropdown-divider" />
                        <a href="#" class="dropdown-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            My Profile
                        </a>
                        <a href="#" class="dropdown-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                            Orders
                        </a>
                        <a href="#" class="dropdown-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                            Cart
                        </a>
                        <hr class="dropdown-divider" />
                        <form asp-controller="Accounts" asp-action="LogoutPost" method="post" class="m-0">
                            <button type="submit" class="dropdown-item text-danger">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                                Log out
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
            }
        </div>
    </nav>

    <!-- ═══════════ HERO SECTION ═══════════ -->
    <section class="hero">
        <div class="hero-content">

            <!-- Badge -->
            <div class="hero-badge">
                <span class="dot"></span>
                New arrivals are live — Check them out
            </div>

            <!-- Headline -->
            <h1>
                Shop the Future of
                <span class="gradient-text">Online Shopping</span>
            </h1>

            <!-- Subtitle -->
            <p>
                Discover a curated collection of premium products with lightning-fast delivery,
                secure payments, and prices that make you smile.
            </p>

            <!-- Call-to-Action Buttons -->
            <div class="hero-actions">
                <a asp-controller="Accounts" asp-action="Login" class="btn-hero btn-hero-primary">
                    Start Shopping
                </a>
                <a href="#products-section" class="btn-hero btn-hero-outline">
                    Explore Products
                </a>
            </div>

            <!-- Stats -->
            <div class="hero-stats">
                <div class="stat-item">
                    <div class="stat-number">@(Model?.Count() ?? 0)<span class="highlight">+</span></div>
                    <div class="stat-label">Products</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <div class="stat-number">50<span class="highlight">K+</span></div>
                    <div class="stat-label">Happy Customers</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <div class="stat-number">99<span class="highlight">%</span></div>
                    <div class="stat-label">Satisfaction</div>
                </div>
            </div>

        </div>
    </section>

    <!-- ═══════════ CATEGORIES & PRODUCTS ═══════════ -->
    <section class="products-section" id="products-section">
        <div class="section-container">
            <div class="section-header">
                <h2>Our Collection</h2>
                <p>Browse through our premium selection of products</p>
            </div>

            <!-- Categories Filter -->
            <div class="categories-filter" id="category-filters">
                <button class="category-pill active" data-filter="all">
                    <span class="cat-emoji">🌟</span>
                    <span class="cat-name">All Products</span>
                </button>
                @foreach (var category in allCategories)
                {
                    <button class="category-pill" data-filter="@((int)category)">
                        <span class="cat-name">@category.ToString().Replace("And", " & ")</span>
                    </button>
                }
            </div>

            <!-- Products Grid -->
            <div class="products-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        var imgSrc = !string.IsNullOrEmpty(product.ProductImage)
                            ? $"data:{product.ProductImageContentType};base64,{product.ProductImage}"
                            : "https://placehold.co/400x300/1e1b4b/a855f7?text=No+Image";

                        <div class="product-card" data-category="@product.CategoryId">
                            <div class="product-img-wrapper">
                                <img src="@imgSrc" alt="@product.ProductName" class="product-img" />
                                <div class="product-badge">@product.CategoryName?.ToString()</div>
                            </div>
                            <div class="product-info">
                                <h3 class="product-title">@product.ProductName</h3>
                                <div class="product-price-row">
                                    <span class="product-price">$@product.ProductPrice.ToString("0.00")</span>
                                    <span class="product-stock @(product.ProductStockQuantity <= 5 ? "low-stock" : "")">
                                        @(product.ProductStockQuantity > 0 ? $"{product.ProductStockQuantity} in stock" : "Out of stock")
                                    </span>
                                </div>
                                <div class="product-actions">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId" class="btn-details">
                                        Show More
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                        </div>
                        <h3>No products found</h3>
                        <p>We are currently updating our inventory. Please check back later.</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ═══════════ FEATURES SECTION ═══════════ -->
    <section class="features" id="features">
        <div class="features-header">
            <h2>Why Choose Us</h2>
            <p>Everything you need for a world-class shopping experience</p>
        </div>

        <div class="features-grid">

            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon purple">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                    </svg>
                </div>
                <h3>Lightning Fast</h3>
                <p>Blazing-fast search and checkout. Your order is processed in seconds, not minutes.</p>
            </div>

            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon cyan">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0110 0v4" />
                    </svg>
                </div>
                <h3>Secure Payments</h3>
                <p>Bank-grade encryption protects every transaction. Shop with complete peace of mind.</p>
            </div>

            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon blue">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="3" width="15" height="13" />
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
                        <circle cx="5.5" cy="18.5" r="2.5" />
                        <circle cx="18.5" cy="18.5" r="2.5" />
                    </svg>
                </div>
                <h3>Free Delivery</h3>
                <p>Free shipping on all orders over $50. Track your package in real-time, from warehouse to door.</p>
            </div>

        </div>
    </section>

    <!-- ═══════════ HOW IT WORKS ═══════════ -->
    <section class="how-it-works" id="how-it-works">
        <div class="section-container">
            <div class="section-header">
                <h2>How It Works</h2>
                <p>From browsing to unboxing — it's as simple as 1-2-3</p>
            </div>

            <div class="steps-row">
                <!-- Step 1 -->
                <div class="step-card">
                    <div class="step-number">1</div>
                    <div class="step-icon purple">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </div>
                    <h3>Browse & Discover</h3>
                    <p>Explore thousands of products across 10 categories. Filter, search, and find exactly what you need.</p>
                </div>

                <div class="step-connector">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                </div>

                <!-- Step 2 -->
                <div class="step-card">
                    <div class="step-number">2</div>
                    <div class="step-icon cyan">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1" />
                            <circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" />
                        </svg>
                    </div>
                    <h3>Add to Cart</h3>
                    <p>Build your perfect order. Adjust quantities, compare options, and check out when you're ready.</p>
                </div>

                <div class="step-connector">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                </div>

                <!-- Step 3 -->
                <div class="step-card">
                    <div class="step-number">3</div>
                    <div class="step-icon blue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                    </div>
                    <h3>Order & Enjoy</h3>
                    <p>Secure checkout, real-time order tracking, and fast delivery right to your door.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ CATEGORIES ═══════════ -->
    <section class="categories" id="categories">
        <div class="section-container">
            <div class="section-header">
                <h2>Browse Categories</h2>
                <p>Find what you love across our curated collections</p>
            </div>

            <div class="categories-grid">
                <div class="category-pill">
                    <span class="cat-emoji">💻</span>
                    <span class="cat-name">Electronics</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">👕</span>
                    <span class="cat-name">Clothing</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">🏠</span>
                    <span class="cat-name">Home Appliances</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">📚</span>
                    <span class="cat-name">Books</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">💄</span>
                    <span class="cat-name">Beauty</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">⚽</span>
                    <span class="cat-name">Sports</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">🎮</span>
                    <span class="cat-name">Toys & Games</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">🚗</span>
                    <span class="cat-name">Automotive</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">💊</span>
                    <span class="cat-name">Health Care</span>
                </div>
                <div class="category-pill">
                    <span class="cat-emoji">🖊️</span>
                    <span class="cat-name">Office Supplies</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ CTA BANNER ═══════════ -->
    <section class="cta-banner">
        <div class="cta-content">
            <h2>Ready to Start Shopping?</h2>
            <p>Create your free account and get access to exclusive deals, personalized recommendations, and lightning-fast checkout.</p>
            <div class="cta-actions">
                <a asp-controller="Accounts" asp-action="Register" class="btn-hero btn-hero-primary">Create Free Account</a>
                <a asp-controller="Accounts" asp-action="Login" class="btn-hero btn-hero-outline">Sign In</a>
            </div>
        </div>
    </section>

    <!-- ═══════════ FOOTER ═══════════ -->
    <footer class="landing-footer">
        <p>&copy; 2025 E-Commerce. All rights reserved.</p>
        <p>Built with <a href="#">ASP.NET Core</a></p>
    </footer>

</div>

<!-- Scripts -->
<script>
    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        navbar.classList.toggle('scrolled', window.scrollY > 40);
    });

    // User Profile Dropdown
    const userProfileBtn = document.querySelector('.user-profile-btn');
    const userDropdownWrapper = document.querySelector('.user-dropdown-wrapper');
    
    if (userProfileBtn && userDropdownWrapper) {
        userProfileBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            userDropdownWrapper.classList.toggle('active');
        });

        document.addEventListener('click', (e) => {
            if (!userDropdownWrapper.contains(e.target)) {
                userDropdownWrapper.classList.remove('active');
            }
        });
    }

    // Category Filtering Logic
    const categoryBtns = document.querySelectorAll('.category-pill');
    const productCards = document.querySelectorAll('.product-card');

    categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            // Remove active class from all
            categoryBtns.forEach(b => b.classList.remove('active'));
            // Add active class to clicked
            btn.classList.add('active');

            const filterValue = btn.getAttribute('data-filter');

            productCards.forEach(card => {
                if (filterValue === 'all') {
                    card.style.display = 'flex';
                } else {
                    if (card.getAttribute('data-category') === filterValue) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                }
            });
        });
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });

    // Intersection Observer for feature cards fade-in
    const observerOptions = { threshold: 0.15, rootMargin: '0px 0px -50px 0px' };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
                entry.target.style.animation = `fadeInUp 0.6s var(--ease-out) ${index * 0.12}s forwards`;
                entry.target.style.opacity = '0';
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.feature-card').forEach(card => {
        card.style.opacity = '0';
        observer.observe(card);
    });

    // Also observe new sections
    document.querySelectorAll('.step-card, .cta-content, .product-card').forEach(el => {
        el.style.opacity = '0';
        observer.observe(el);
    });

    // Close any auth success alerts auto after some time if we had any
    const tempAlert = document.querySelector('.alert');
    if(tempAlert) {
        setTimeout(() => { tempAlert.style.display = 'none'; }, 5000);
    }
</script>

</body>
</html>
