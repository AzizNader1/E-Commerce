@model IEnumerable<E_Commerce.MVC.DTOs.ProductDTOs.ProductDto>

@{
    ViewData["Title"] = "Home";
    Layout = null;
    var userName = (string?)TempData["UserName"];

    // Get all category values for filtering
    var allCategories = Enum.GetValues(typeof(E_Commerce.MVC.Models.CategoriesCollections))
                            .Cast<E_Commerce.MVC.Models.CategoriesCollections>()
                            .ToList();

    // Category display names mapping
    var categoryDisplayNames = new Dictionary<string, string>
    {
        { "Electronics", "Electronics" },
        { "Clothing", "Clothing" },
        { "HomeAppliances", "Home Appliances" },
        { "Books", "Books" },
        { "BeautyProducts", "Beauty" },
        { "SportsEquipment", "Sports" },
        { "ToysAndGames", "Toys & Games" },
        { "AutomotiveParts", "Automotive" },
        { "HealthAndPersonalCare", "Health Care" },
        { "OfficeSupplies", "Office Supplies" }
    };

    // Category emojis mapping
    var categoryEmojis = new Dictionary<string, string>
    {
        { "Electronics", "💻" },
        { "Clothing", "👕" },
        { "HomeAppliances", "🏠" },
        { "Books", "📚" },
        { "BeautyProducts", "💄" },
        { "SportsEquipment", "⚽" },
        { "ToysAndGames", "🎮" },
        { "AutomotiveParts", "🚗" },
        { "HealthAndPersonalCare", "💊" },
        { "OfficeSupplies", "🖊️" }
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-Commerce — Shop the Future</title>
    <meta name="description" content="Discover premium products with a seamless shopping experience. Fast delivery, secure payments, and unbeatable prices." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Design System + Home CSS -->
    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/shared/home.css" />
    <style>
        /* Toast Notification Styles */
        .toast-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-width: 400px;
        }

        .toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            border-radius: 12px;
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            transform-origin: top right;
            position: relative;
            overflow: hidden;
        }

            .toast.toast-error {
                background: rgba(239, 68, 68, 0.15);
                border-color: rgba(239, 68, 68, 0.3);
            }

            .toast.toast-info {
                background: rgba(59, 130, 246, 0.15);
                border-color: rgba(59, 130, 246, 0.3);
            }

        .toast-icon {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

            .toast-icon svg {
                width: 100%;
                height: 100%;
            }

        .toast-success .toast-icon {
            color: #10b981;
        }

        .toast-error .toast-icon {
            color: #ef4444;
        }

        .toast-info .toast-icon {
            color: #3b82f6;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 2px;
        }

        .toast-message {
            font-size: 0.8125rem;
            color: rgba(255, 255, 255, 0.8);
        }

        .toast-close {
            width: 20px;
            height: 20px;
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

            .toast-close:hover {
                color: #fff;
                background: rgba(255, 255, 255, 0.1);
            }

            .toast-close svg {
                width: 16px;
                height: 16px;
            }

        .toast-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: rgba(16, 185, 129, 0.6);
            border-radius: 0 0 12px 12px;
            animation: progress 5s linear forwards;
        }

        .toast-error .toast-progress {
            background: rgba(239, 68, 68, 0.6);
        }

        .toast-info .toast-progress {
            background: rgba(59, 130, 246, 0.6);
        }

        keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }

            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        keyframes slideOut {
            from {
                opacity: 1;
                transform: translateX(0) scale(1);
            }

            to {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }
        }

        keyframes progress {
            from {
                width: 100%;
            }

            to {
                width: 0%;
            }
        }

        .toast.hiding {
            animation: slideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Cart Button Styles */
        .nav-btn-cart {
            display: flex;
            align-items: center;
            gap: 6px;
            position: relative;
        }

        .cart-badge {
            position: absolute;
            top: -4px;
            right: -8px;
            background: linear-gradient(135deg, #a855f7, #6366f1);
            color: white;
            font-size: 0.65rem;
            font-weight: 700;
            min-width: 18px;
            height: 18px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
        }

        media (max-width: 576px) {
            .toast-container {
                right: 12px;
                left: 12px;
                max-width: none;
            }
        }
    </style>
</head>
<body>

    <!-- Toast Notification Container -->
    <div class="toast-container" id="toastContainer">
        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="toast toast-success" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Success!</div>
                    <div class="toast-message">@successMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="toast toast-error" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Error!</div>
                    <div class="toast-message">@errorMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }

        @if (TempData["InfoMessage"] is string infoMsg)
        {
            <div class="toast toast-info" role="alert">
                <div class="toast-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                    </svg>
                </div>
                <div class="toast-content">
                    <div class="toast-title">Info</div>
                    <div class="toast-message">@infoMsg</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="toast-progress"></div>
            </div>
        }
    </div>

    <div class="landing-page">

        <!-- Background Orbs -->
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <!-- Particles -->
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>

        <!-- ═══════════ NAVBAR ═══════════ -->
        <nav class="landing-nav" id="navbar">
            <a class="nav-logo" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 01-8 0" />
                    </svg>
                </div>
                <span class="logo-text">E-<span>Commerce</span></span>
            </a>

            <div class="nav-actions">
                @if (!string.IsNullOrEmpty(userName))
                {
                    <!-- Cart Button -->
                    <a asp-controller="Carts" asp-action="Index" class="nav-btn nav-btn-ghost nav-btn-cart">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        <span>Cart</span>
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="nav-btn nav-btn-ghost">My Orders</a>
                    <a asp-controller="Accounts" asp-action="UserProfile" asp-route-userName="@userName" class="nav-btn nav-btn-ghost">My Profile</a>
                    <a asp-controller="Accounts" asp-action="Logout" class="nav-btn nav-btn-ghost">Logout</a>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login" class="nav-btn nav-btn-ghost">Sign In</a>
                    <a asp-controller="Accounts" asp-action="Register" class="nav-btn nav-btn-primary">Get Started</a>
                }
            </div>
        </nav>

        <!-- ═══════════ HERO SECTION ═══════════ -->
        <section class="hero">
            <div class="hero-content">

                <!-- Badge -->
                <div class="hero-badge">
                    <span class="dot"></span>
                    New arrivals are live — Check them out
                </div>

                <!-- Headline -->
                <h1>
                    Shop the Future of
                    <span class="gradient-text">Online Shopping</span>
                </h1>

                <!-- Subtitle -->
                <p>
                    Discover a curated collection of premium products with lightning-fast delivery,
                    secure payments, and prices that make you smile.
                </p>

                <!-- Call-to-Action Buttons -->
                <div class="hero-actions">
                    <a asp-controller="Accounts" asp-action="Login" class="btn-hero btn-hero-primary">
                        Start Shopping
                    </a>
                    <a href="#products-section" class="btn-hero btn-hero-outline">
                        Explore Products
                    </a>
                </div>

                <!-- Stats -->
                <div class="hero-stats">
                    <div class="stat-item">
                        <div class="stat-number">@(Model?.Count() ?? 0)<span class="highlight">+</span></div>
                        <div class="stat-label">Products</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <div class="stat-number">50<span class="highlight">K+</span></div>
                        <div class="stat-label">Happy Customers</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <div class="stat-number">99<span class="highlight">%</span></div>
                        <div class="stat-label">Satisfaction</div>
                    </div>
                </div>

            </div>
        </section>

        <!-- ═══════════ CATEGORIES & PRODUCTS ═══════════ -->
        <section class="products-section" id="products-section">
            <div class="section-container">
                <div class="section-header">
                    <h2>Our Collection</h2>
                    <p>Browse through our premium selection of products</p>
                </div>

                <!-- Categories Filter -->
                <div class="categories-filter" id="category-filters">
                    <button class="category-pill active" data-category="all" onclick="filterProducts('all')">
                        <span class="cat-emoji">🌟</span>
                        <span class="cat-name">All Products</span>
                    </button>
                    @foreach (var category in allCategories)
                    {
                        var categoryName = category.ToString();
                        var categoryId = (int)category;
                        var emoji = categoryEmojis.ContainsKey(categoryName) ? categoryEmojis[categoryName] : "📦";
                        var displayName = categoryDisplayNames.ContainsKey(categoryName) ? categoryDisplayNames[categoryName] : category.ToString();

                        <button class="category-pill" data-category="@categoryId" onclick="filterProducts(@categoryId)">
                            <span class="cat-emoji">@emoji</span>
                            <span class="cat-name">@displayName</span>
                        </button>
                    }
                </div>

                <!-- Products Grid -->
                <div class="products-grid" id="products-grid">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var product in Model)
                        {
                            var imgSrc = product.ProductImage != null && product.ProductImage.Length > 0
                            ? $"data:{product.ProductImageContentType};base64,{Convert.ToBase64String(product.ProductImage)}"
                            : "https://placehold.co/400x300/1e1b4b/a855f7?text=No+Image";

                            <div class="product-card" data-category="@product.CategoryId">
                                <div class="product-img-wrapper">
                                    <img src="@imgSrc" alt="@product.ProductName" class="product-img" />
                                    <div class="product-badge">@product.CategoryName?.ToString()</div>
                                </div>
                                <div class="product-info">
                                    <h3 class="product-title">@product.ProductName</h3>
                                    <div class="product-price-row">
                                        <span class="product-price">$@product.ProductPrice.ToString("0.00")</span>
                                        <span class="product-stock @(product.ProductStockQuantity <= 5 ? "low-stock" : "")">
                                            @(product.ProductStockQuantity > 0 ? $"{product.ProductStockQuantity} in stock" : "Out of stock")
                                        </span>
                                    </div>
                                    <div class="product-actions">
                                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId" class="btn-details">
                                            Show More
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                            </div>
                            <h3>No products found</h3>
                            <p>We are currently updating our inventory. Please check back later.</p>
                        </div>
                    }
                </div>

                <!-- No products message for filtered category -->
                <div id="no-products-message" class="empty-state" style="display: none;">
                    <div class="empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                    </div>
                    <h3>No products in this category</h3>
                    <p>Try selecting a different category or view all products.</p>
                </div>
            </div>
        </section>

        <!-- ═══════════ FEATURES SECTION ═══════════ -->
        <section class="features" id="features">
            <div class="features-header">
                <h2>Why Choose Us</h2>
                <p>Everything you need for a world-class shopping experience</p>
            </div>

            <div class="features-grid">

                <!-- Feature 1 -->
                <div class="feature-card">
                    <div class="feature-icon purple">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                    </div>
                    <h3>Lightning Fast</h3>
                    <p>Blazing-fast search and checkout. Your order is processed in seconds, not minutes.</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card">
                    <div class="feature-icon cyan">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                    </div>
                    <h3>Secure Payments</h3>
                    <p>Bank-grade encryption protects every transaction. Shop with complete peace of mind.</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card">
                    <div class="feature-icon blue">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="3" width="15" height="13" />
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
                            <circle cx="5.5" cy="18.5" r="2.5" />
                            <circle cx="18.5" cy="18.5" r="2.5" />
                        </svg>
                    </div>
                    <h3>Free Delivery</h3>
                    <p>Free shipping on all orders over $50. Track your package in real-time, from warehouse to door.</p>
                </div>

            </div>
        </section>

        <!-- ═══════════ HOW IT WORKS ═══════════ -->
        <section class="how-it-works" id="how-it-works">
            <div class="section-container">
                <div class="section-header">
                    <h2>How It Works</h2>
                    <p>From browsing to unboxing — it's as simple as 1-2-3</p>
                </div>

                <div class="steps-row">
                    <!-- Step 1 -->
                    <div class="step-card">
                        <div class="step-number">1</div>
                        <div class="step-icon purple">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                        </div>
                        <h3>Browse & Discover</h3>
                        <p>Explore thousands of products across 10 categories. Filter, search, and find exactly what you need.</p>
                    </div>

                    <div class="step-connector">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </div>

                    <!-- Step 2 -->
                    <div class="step-card">
                        <div class="step-number">2</div>
                        <div class="step-icon cyan">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="21" r="1" />
                                <circle cx="20" cy="21" r="1" />
                                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" />
                            </svg>
                        </div>
                        <h3>Add to Cart</h3>
                        <p>Build your perfect order. Adjust quantities, compare options, and check out when you're ready.</p>
                    </div>

                    <div class="step-connector">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </div>

                    <!-- Step 3 -->
                    <div class="step-card">
                        <div class="step-number">3</div>
                        <div class="step-icon blue">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
                                <polyline points="22 4 12 14.01 9 11.01" />
                            </svg>
                        </div>
                        <h3>Order & Enjoy</h3>
                        <p>Secure checkout, real-time order tracking, and fast delivery right to your door.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══════════ CATEGORIES ═══════════ -->
        <section class="categories" id="categories">
            <div class="section-container">
                <div class="section-header">
                    <h2>Browse Categories</h2>
                    <p>Find what you love across our curated collections</p>
                </div>

                <div class="categories-grid">
                    @foreach (var category in allCategories)
                    {
                        var categoryId = (int)category;
                        var categoryName = category.ToString();
                        var emoji = categoryEmojis.ContainsKey(categoryName) ? categoryEmojis[categoryName] : "📦";
                        var displayName = categoryDisplayNames.ContainsKey(categoryName) ? categoryDisplayNames[categoryName] : category.ToString();

                        <div class="category-pill" style="cursor: pointer;" onclick="scrollToProductsAndFilter(@categoryId)">
                            <span class="cat-emoji">@emoji</span>
                            <span class="cat-name">@displayName</span>
                        </div>
                    }
                </div>
            </div>
        </section>

        <!-- ═══════════ CTA BANNER ═══════════ -->
        <section class="cta-banner">
            <div class="cta-content">
                <h2>Ready to Start Shopping?</h2>
                <p>Create your free account and get access to exclusive deals, personalized recommendations, and lightning-fast checkout.</p>
                <div class="cta-actions">
                    <a asp-controller="Accounts" asp-action="Register" class="btn-hero btn-hero-primary">Create Free Account</a>
                    <a asp-controller="Accounts" asp-action="Login" class="btn-hero btn-hero-outline">Sign In</a>
                </div>
            </div>
        </section>

        <!-- ═══════════ FOOTER ═══════════ -->
        <footer class="landing-footer">
            <p>&copy; 2025 E-Commerce. All rights reserved.</p>
            <p>Built with <a href="#">ASP.NET Core</a></p>
        </footer>

    </div>

    <!-- Scripts -->
    <script>
        // Toast Notification Functions
        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('hiding');
            setTimeout(() => {
                toast.remove();
            }, 300);
        }

        // Auto-dismiss toasts after 5 seconds
        document.querySelectorAll('.toast').forEach(toast => {
            setTimeout(() => {
                if (toast && !toast.classList.contains('hiding')) {
                    toast.classList.add('hiding');
                    setTimeout(() => {
                        toast.remove();
                    }, 300);
                }
            }, 5000);
        });

        // Navbar scroll effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 40);
        });

        // ═══════════ CATEGORY FILTER FUNCTIONALITY ═══════════
        function filterProducts(categoryId) {
            // Update active state on buttons
            const allButtons = document.querySelectorAll('#category-filters .category-pill');
            allButtons.forEach(btn => {
                btn.classList.remove('active');
                if (btn.getAttribute('data-category') == categoryId ||
                    (categoryId === 'all' && btn.getAttribute('data-category') === 'all')) {
                    btn.classList.add('active');
                }
            });

            // Filter products
            const productCards = document.querySelectorAll('.product-card');
            const noProductsMsg = document.getElementById('no-products-message');
            let visibleCount = 0;

            productCards.forEach(card => {
                const cardCategory = card.getAttribute('data-category');

                if (categoryId === 'all' || cardCategory == categoryId) {
                    card.style.display = 'flex';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            // Show/hide no products message
            if (visibleCount === 0 && categoryId !== 'all') {
                noProductsMsg.style.display = 'block';
            } else {
                noProductsMsg.style.display = 'none';
            }
        }

        // Scroll to products and filter by category
        function scrollToProductsAndFilter(categoryId) {
            // Scroll to products section
            document.getElementById('products-section').scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });

            // Apply filter after short delay
            setTimeout(() => {
                filterProducts(categoryId);
            }, 500);
        }

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const href = this.getAttribute('href');
                if (href && href !== '#') {
                    e.preventDefault();
                    const target = document.querySelector(href);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        });

        // Intersection Observer for fade-in animations
        const observerOptions = { threshold: 0.15, rootMargin: '0px 0px -50px 0px' };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    entry.target.style.animation = `fadeInUp 0.6s var(--ease-out) ${index * 0.12}s forwards`;
                    entry.target.style.opacity = '0';
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.feature-card').forEach(card => {
            card.style.opacity = '0';
            observer.observe(card);
        });

        document.querySelectorAll('.step-card, .cta-content, .product-card').forEach(el => {
            el.style.opacity = '0';
            observer.observe(el);
        });
    </script>

</body>
</html>
