@model IEnumerable<E_Commerce.MVC.DTOs.UserDTOs.UserDto>

@{
    ViewData["Title"] = "Manage Users";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Users</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/shared/design-system.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" />
</head>
<body>
    <div class="admin-page">
        <div class="admin-wrapper">
            <header class="admin-header">
                <div>
                    <h1>Users</h1>
                    <p>View, update and delete user accounts.</p>
                </div>
                <div class="admin-actions">
                    <a asp-action="Index" class="btn-admin-ghost">Admin home</a>
                </div>
            </header>

            <section class="admin-card">
                @if (TempData["SuccessMessage"] is string success)
                {
                    <div class="admin-alert admin-alert-success">@success</div>
                }
                @if (TempData["ErrorMessage"] is string error)
                {
                    <div class="admin-alert admin-alert-error">@error</div>
                }

                <div class="admin-table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Full Name</th>
                                <th>Phone</th>
                                @* <th></th> *@
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var u in Model)
                                {
                                    <tr>
                                        <td>@u.UserId</td>
                                        <td>@u.UserName</td>
                                        <td>@u.UserEmail</td>
                                        <td>@(u.UserFullName ?? "-")</td>
                                        <td>@u.UserPhoneNumber</td>
                                        @* <td>
                                            <div style="display:flex; gap:6px;">
                                                <a asp-action="EditUser" asp-route-id="@u.UserId" class="btn-admin-ghost" style="padding:4px 10px; font-size:0.75rem;">Edit</a>
                                                <form asp-action="DeleteUser" asp-route-id="@u.UserId" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn-admin-ghost" style="padding:4px 10px; font-size:0.75rem; border-color:rgba(239,68,68,0.4); color:#f87171;" onclick="return confirm('Are you sure you want to delete this user?');">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td> *@
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6">No users found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</body>
</html>
